+// Contains layout and styling for the side panel. Currently, it just has navigation
+// and a somewhat working searchbar (valid URLs work, terms don't).
+class SidePanelView : public views::View, public views::TextfieldController {
+  METADATA_HEADER(SidePanelView, views::View)
+
+  public:
+    explicit SidePanelView(Browser* browser) : browser_(browser) {
+      auto* root_layout = SetLayoutManager(std::make_unique<views::BoxLayout>(
+          views::BoxLayout::Orientation::kVertical, gfx::Insets(8), 8));
+
+      auto* nav_container = AddChildView(std::make_unique<views::View>());
+      nav_container->SetLayoutManager(std::make_unique<views::BoxLayout>(
+          views::BoxLayout::Orientation::kHorizontal, gfx::Insets::TLBR(20, 0, 0, 0), 4));
+
+      auto make_nav_button = [this](int command_id,
+                                    const gfx::VectorIcon& icon,
+                                    std::u16string tooltip) {
+        auto button = views::CreateVectorImageButtonWithNativeTheme(
+          base::BindRepeating(
+            [](Browser* browser, int command_id, const ui::Event&) {
+              if (browser) {
+                chrome::ExecuteCommand(browser, command_id);
+              }
+            },
+            browser_, command_id),
+          icon);
+
+        button->SetTooltipText(tooltip);
+        button->SetAccessibleName(tooltip);
+        button->SetPreferredSize(gfx::Size(40, 40));
+        views::InstallCircleHighlightPathGenerator(button.get());
+        return button;
+      };
+
+      back_button_ = nav_container->AddChildView(make_nav_button(
+        IDC_BACK, vector_icons::kBackArrowChromeRefreshIcon, u"Back"));
+      forward_button_ = nav_container->AddChildView(make_nav_button(
+          IDC_FORWARD, vector_icons::kForwardArrowChromeRefreshIcon, u"Forward"));
+      refresh_button_ = nav_container->AddChildView(make_nav_button(
+          IDC_RELOAD, vector_icons::kReloadChromeRefreshIcon, u"Refresh"));
+
+      auto* search_container = AddChildView(std::make_unique<views::View>());
+      auto* search_layout = search_container->SetLayoutManager(
+          std::make_unique<views::BoxLayout>(
+              views::BoxLayout::Orientation::kHorizontal, gfx::Insets::VH(6, 10),
+              8));
+
+      search_container->SetBackground(views::CreateRoundedRectBackground(
+          kColorLocationBarBackground, 30));
+
+      search_container->AddChildView(std::make_unique<views::ImageView>(
+          ui::ImageModel::FromVectorIcon(vector_icons::kSearchChromeRefreshIcon,
+                                        ui::kColorIcon)));
+
+      search_bar_ = search_container->AddChildView(std::make_unique<views::Textfield>());
+      search_bar_->SetPlaceholderText(u"Search or enter address");
+      search_bar_->SetBorder(nullptr);
+      search_bar_->SetBackgroundColor(kColorLocationBarBackground);
+      search_layout->SetFlexForView(search_bar_, 1);
+
+      search_bar_->SetController(this);
+
+      root_layout->SetFlexForView(search_container, 0);
+    }
+
+    SidePanelView(const SidePanelView&) = delete;
+    SidePanelView& operator=(const SidePanelView&) = delete;
+    ~SidePanelView() override;
+
+    views::ImageButton* back_button() const { return back_button_; }
+    views::ImageButton* forward_button() const { return forward_button_; }
+    views::ImageButton* refresh_button() const { return refresh_button_; }
+    views::Textfield* search_bar() const { return search_bar_; }
+  
+  private:
+    raw_ptr<Browser> browser_ = nullptr;
+    raw_ptr<views::ImageButton> back_button_ = nullptr;
+    raw_ptr<views::ImageButton> forward_button_ = nullptr;
+    raw_ptr<views::ImageButton> refresh_button_ = nullptr;
+    raw_ptr<views::Textfield> search_bar_ = nullptr;
+
+    bool HandleKeyEvent(views::Textfield* sender,
+                        const ui::KeyEvent& key_event) override {
+      if (sender != search_bar_ ||
+          key_event.type() != ui::EventType::kKeyPressed ||
+          key_event.key_code() != ui::VKEY_RETURN || !browser_) {
+        return false;
+      }
+
+      std::u16string text(search_bar_->GetText());
+      if (text.empty()) {
+        return false;
+      }
+
+      GURL url = url_formatter::FixupURL(base::UTF16ToUTF8(text));
+
+      NavigateParams params(browser_, url, ui::PAGE_TRANSITION_TYPED);
+      params.window_action = NavigateParams::WindowAction::kShowWindow;
+      params.disposition = WindowOpenDisposition::CURRENT_TAB;
+      Navigate(&params);
+      return true;
+    }
+};
+
+SidePanelView::~SidePanelView() = default;
+
+BEGIN_METADATA(SidePanelView)
+END_METADATA
