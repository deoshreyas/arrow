+// A view that sits between the left and right panels and allows resizing them by
+// dragging. It acts as a draggable handle and enforces a minimum and maximum width 
+// for the left panel, and a minimum width for the right panel.
+class PanelResizeHandle : public views::View,
+                               public views::ResizeAreaDelegate {
+ METADATA_HEADER(PanelResizeHandle, views::View)
+
+ public:
+  PanelResizeHandle(views::View* left_panel,
+                         int min_left_width,
+                         int max_left_width,
+                         int min_right_width)
+      : left_panel_(left_panel),
+        min_left_width_(min_left_width),
+        max_left_width_(max_left_width),
+        min_right_width_(min_right_width) {
+    SetLayoutManager(std::make_unique<views::FillLayout>());
+    AddChildView(std::make_unique<views::ResizeArea>(this));
+    SetPreferredSize(gfx::Size(kResizeHandleWidth, 1));
+    SetBackground(views::CreateSolidBackground(kColorToolbarSeparator));
+  }
+
+  PanelResizeHandle(const PanelResizeHandle&) = delete;
+  PanelResizeHandle& operator=(const PanelResizeHandle&) = delete;
+  ~PanelResizeHandle() override = default;
+
+ private:
+  void OnResize(int resize_amount, bool done_resizing) override {
+    if (!left_panel_ || !parent()) {
+      return;
+    }
+
+    const int available_width = parent()->width() - kResizeHandleWidth;
+    if (available_width <= 0) {
+      return;
+    }
+
+    const int current_left_width =
+        left_panel_->width() > 0 ? left_panel_->width()
+                                 : left_panel_->GetPreferredSize().width();
+    if (!initial_left_width_.has_value()) {
+      initial_left_width_ = current_left_width;
+    }
+
+    const int max_left_by_right = available_width - min_right_width_;
+    const int effective_max_left = std::min(max_left_width_, max_left_by_right);
+    if (effective_max_left < min_left_width_) {
+      return;
+    }
+
+    const int target_left_width =
+        std::clamp(initial_left_width_.value() + resize_amount,
+                   min_left_width_, effective_max_left);
+    left_panel_->SetPreferredSize(gfx::Size(target_left_width, 1));
+    parent()->InvalidateLayout();
+
+    if (done_resizing) {
+      initial_left_width_.reset();
+    }
+  }
+
+  static constexpr int kResizeHandleWidth = 5;
+
+  raw_ptr<views::View> left_panel_ = nullptr;
+  const int min_left_width_;
+  const int max_left_width_;
+  const int min_right_width_;
+  std::optional<int> initial_left_width_;
+};
+
+BEGIN_METADATA(PanelResizeHandle)
+END_METADATA
